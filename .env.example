# Token du bot Discord (Portail développeur Discord)
DISCORD_TOKEN=your_discord_bot_token_here

# ID du channel Discord où poster les annonces
DISCORD_CHANNEL_ID=your_channel_id_here

# Clé football-data.org
API_KEY=your_football_data_key_here

# Intervalle de poll en millisecondes pendant un match actif (défaut : 90000 = 90s)
POLL_INTERVAL_MS=90000
